// This is the BlueCollar Prisma schema
// Built on Stellar — connecting skilled workers with users
//
// ═══════════════════════════════════════════════════════════════
// COMPLIANCE: Encryption-at-Rest & PII Management
// ═══════════════════════════════════════════════════════════════
// All columns marked `@encrypted` MUST be encrypted at the
// application layer using AES-256-GCM before being stored.
// Keys are managed via AWS KMS / HashiCorp Vault (see docs/COMPLIANCE.md).
// PII fields are explicitly annotated below for audit traceability.
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id      String  @id @default(cuid())
  city    String
  state   String?
  country String
  lat     Float?
  lng     Float?
  users   User[]
  workers Worker[]
  jobs    Job[]
}

model User {
  id                      String    @id @default(cuid())
  /// @encrypted — PII (High sensitivity, AES-256-GCM)
  email                   String    @unique
  /// @encrypted — Argon2id hash (never plaintext)
  password                String?
  /// @encrypted — PII (Medium sensitivity, AES-256-GCM)
  googleId                String?   @unique
  firstName               String
  lastName                String
  role                    Role      @default(user)
  walletAddress           String?
  avatar                  String?
  bio                     String?
  /// @encrypted — PII (High sensitivity, AES-256-GCM)
  phone                   String?
  verified                Boolean   @default(false)
  /// @encrypted — Critical token (Argon2id hash)
  verificationToken       String?
  verificationTokenExpiry DateTime?
  /// @encrypted — Critical token (Argon2id hash)
  resetToken              String?   @unique
  resetTokenExpiry        DateTime?
  /// @encrypted — Critical (AES-256-GCM)
  twoFactorSecret         String?
  twoFactorEnabled        Boolean   @default(false)
  /// @encrypted — Critical (AES-256-GCM, each code encrypted)
  twoFactorBackupCodes    String[]  @default([])
  referralCode            String?   @unique
  onboardingCompleted     Boolean   @default(false)
  locationId              String?
  location                Location? @relation(fields: [locationId], references: [id])
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?
  workers                 Worker[]
  reviews                 Review[]             @relation("ReviewUser")
  authoredReviews         Review[]             @relation("ReviewAuthor")
  bookmarks               Bookmark[]
  contactRequests         ContactRequest[]
  pushSubscriptions       PushSubscription[]
  disputesFiled           Dispute[]            @relation("DisputesFiled")
  disputesResolved        Dispute[]            @relation("DisputesResolved")
  interactions            UserInteraction[]
  webhooks                WebhookSubscription[]
  verificationRequests    VerificationRequest[] @relation("VerificationRequests")
  verificationReviews     VerificationRequest[] @relation("VerificationReviews")
  auditLogs               AuditLog[]
  referralsMade               Referral[]            @relation("ReferralsMade")
  referralUsed                Referral?             @relation("ReferralUsed")
  jobs                        Job[]                 @relation("JobsPosted")
  jobMessagesSent             JobMessage[]          @relation("JobMessagesSent")
  jobMessagesReceived         JobMessage[]          @relation("JobMessagesReceived")
  refreshTokens               RefreshToken[]
  devices                     Device[]
  notificationPreferences     NotificationPreferences?
  notifications               Notification[]
  helpfulVotes                ReviewHelpful[]
  conversations               ConversationParticipant[]
  messagesSent                Message[]
  initiatedConversations      Conversation[]           @relation("ConversationInitiator")
  stellarAccounts             StellarAccount[]
  /// Workers created by this user (audit trail — #833)
  workersCreated              Worker[]             @relation("WorkerCreatedBy")
  /// Workers last updated by this user (audit trail — #833)
  workersUpdated              Worker[]             @relation("WorkerUpdatedBy")
  bookingsRequested           Booking[]            @relation("BookingRequester")

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@index([createdAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workers     Worker[]
  jobs        Job[]
}

model Worker {
  id                  String          @id @default(cuid())
  name                String
  bio                 String?
  avatar              String?
  /// 64×64 WebP thumbnail URL (generated by Sharp on upload)
  imageThumb          String?
  /// 256×256 WebP medium URL (generated by Sharp on upload)
  imageMedium         String?
  /// 800×800 WebP full-size URL (generated by Sharp on upload)
  imageFull           String?
  /// @encrypted — PII (High sensitivity, AES-256-GCM)
  phone               String?
  /// @encrypted — PII (High sensitivity, AES-256-GCM)
  email               String?
  walletAddress       String?
  isActive            Boolean         @default(true)
  isVerified          Boolean         @default(false)
  stellarContractId   String?
  /// PostgreSQL tsvector column — maintained by DB trigger, used for full-text search
  searchVector        Unsupported("tsvector")?
  categoryId          String
  category            Category        @relation(fields: [categoryId], references: [id])
  curatorId           String
  curator             User            @relation(fields: [curatorId], references: [id])
  locationId          String?
  location            Location?       @relation(fields: [locationId], references: [id])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  /// ID of the User who created this listing (audit trail — #833)
  createdById         String?
  createdBy           User?           @relation("WorkerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  /// ID of the User who last modified this listing (audit trail — #833)
  updatedById         String?
  updatedBy           User?           @relation("WorkerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  bookmarks           Bookmark[]
  reviews             Review[]
  availability        Availability[]
  contactRequests     ContactRequest[]
  disputes            Dispute[]
  interactions        UserInteraction[]
  verificationRequests VerificationRequest[]
  insuranceDocuments  InsuranceDocument[]
  portfolioItems      PortfolioItem[]
  subscription        Subscription?
  jobApplications     JobApplication[]
  profileViews        ProfileView[]
  analytics           WorkerAnalytics?
  bookings            Booking[]
  tipEvents           WorkerTipEvent[]

  @@index([isActive, categoryId])
  @@index([curatorId])
  @@index([locationId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
  // ── Covering indexes for common search/filter queries ──
  @@index([isActive, categoryId, createdAt])
  @@index([isActive, isVerified, categoryId])
  @@index([name])                              // full-text prefix search
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  workerId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([userId, workerId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Availability {
  id        String   @id @default(cuid())
  workerId  String
  dayOfWeek Int      // 0=Sun … 6=Sat
  startTime String   // "09:00"
  endTime   String   // "17:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, dayOfWeek])
  @@index([workerId])
  @@index([workerId, dayOfWeek, startTime, endTime]) // covering index for availability filter
}

model PortfolioItem {
  id          String   @id @default(cuid())
  workerId    String
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  imageUrl    String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workerId])
}

model Review {
  id          String        @id @default(cuid())
  workerId    String
  worker      Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?         @relation("ReviewUser", fields: [userId], references: [id], onDelete: Cascade)
  authorId    String
  author      User          @relation("ReviewAuthor", fields: [authorId], references: [id])
  rating      Int
  body        String        @default("")
  comment     String?
  status      ReviewStatus  @default(pending)
  flagged     Boolean       @default(false)
  flagReason  String?
  // Issue #750: Verified transactions
  transactionHash String?   // On-chain transaction hash (tip/escrow)
  isVerified  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  helpfulVotes ReviewHelpful[]

  @@unique([userId, workerId])
  @@index([workerId])
  @@index([workerId, status])
  @@index([authorId])
  @@index([workerId, rating]) // covering index for avg rating aggregation
}

model Subscription {
  id                 String             @id @default(cuid())
  workerId           String             @unique
  worker             Worker             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  tier               SubscriptionTier   @default(free)
  stripeCustomerId   String?
  stripeSubId        String?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Dispute {
  id           String        @id @default(cuid())
  workerId     String
  filedById    String
  reason       String
  evidence     String?
  status       DisputeStatus @default(open)
  resolution   String?
  resolvedById String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  worker       Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  filedBy      User          @relation("DisputesFiled", fields: [filedById], references: [id], onDelete: Cascade)
  resolvedBy   User?         @relation("DisputesResolved", fields: [resolvedById], references: [id])

  @@index([workerId])
  @@index([filedById])
  @@index([status])
}

model UserInteraction {
  id        String          @id @default(cuid())
  userId    String
  workerId  String
  type      InteractionType
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  worker    Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workerId])
}

model WebhookSubscription {
  id        String       @id @default(cuid())
  userId    String
  url       String
  secret    String
  events    String[]
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs      WebhookLog[]

  @@index([userId])
}

model WebhookLog {
  id             String              @id @default(cuid())
  subscriptionId String
  event          String
  payload        Json
  statusCode     Int?
  attempts       Int                 @default(0)
  success        Boolean             @default(false)
  error          String?
  createdAt      DateTime            @default(now())
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

model VerificationRequest {
  id            String             @id @default(cuid())
  workerId      String
  requestedById String
  documentUrl   String
  notes         String?
  status        VerificationStatus @default(pending)
  reviewedById  String?
  reviewNote    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  worker        Worker             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  requestedBy   User               @relation("VerificationRequests", fields: [requestedById], references: [id])
  reviewedBy    User?              @relation("VerificationReviews", fields: [reviewedById], references: [id])

  @@index([workerId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  meta       Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── Issue #329: Worker Response Time Tracking ───────────────────────────────

model ContactRequest {
  id          String               @id @default(cuid())
  workerId    String
  fromUserId  String
  message     String
  status      ContactRequestStatus @default(pending)
  respondedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  worker      Worker               @relation(fields: [workerId], references: [id], onDelete: Cascade)
  fromUser    User                 @relation(fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([workerId, status])
}

// ─── Issue #331: Worker Insurance Verification ───────────────────────────────

model InsuranceDocument {
  id           String          @id @default(cuid())
  workerId     String
  documentUrl  String
  provider     String?
  policyNumber String?
  expiresAt    DateTime
  status       InsuranceStatus @default(pending)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  worker       Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([expiresAt])
}

// ─── Issue #332: Referral System ─────────────────────────────────────────────

model Referral {
  id          String         @id @default(cuid())
  referrerId  String
  refereeId   String?        @unique
  code        String         @unique
  status      ReferralStatus @default(pending)
  rewardGiven Boolean        @default(false)
  createdAt   DateTime       @default(now())
  convertedAt DateTime?
  referrer    User           @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referee     User?          @relation("ReferralUsed", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([code])
}

model Job {
  id            String        @id @default(cuid())
  title         String
  description   String
  budget        Float?
  /// Required skills as a plain string array (e.g. ["plumbing","pipe fitting"])
  skills        String[]      @default([])
  urgency       JobUrgency    @default(normal)
  /// Amount held in escrow (Stellar XLM)
  escrowAmount  Float?
  /// Stellar escrow transaction/contract reference
  escrowTxId    String?
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  locationId    String?
  location      Location?     @relation(fields: [locationId], references: [id])
  postedById    String
  postedBy      User          @relation("JobsPosted", fields: [postedById], references: [id])
  status        JobStatus     @default(open)
  expiresAt     DateTime?
  renewedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  applications  JobApplication[]
  messages      JobMessage[]

  @@index([status])
  @@index([categoryId])
  @@index([postedById])
  @@index([expiresAt])
}

model JobApplication {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId    String
  worker      Worker            @relation(fields: [workerId], references: [id], onDelete: Cascade)
  coverLetter String?
  proposedRate Float?
  status      ApplicationStatus @default(pending)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, workerId])
  @@index([jobId])
  @@index([workerId])
}

// ─── Issue #687: Job messaging between poster and applicant ──────────────────

model JobMessage {
  id         String   @id @default(cuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation("JobMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient  User     @relation("JobMessagesReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  body       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([jobId])
  @@index([senderId])
  @@index([recipientId])
}

// ─── Issue #analytics: Advanced Analytics & Reporting ────────────────────────

model ProfileView {
  id        String   @id @default(cuid())
  workerId  String
  /// @encrypted — PII (Medium sensitivity; retained 30 days then truncated)
  ip        String
  viewedAt  DateTime @default(now())
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, ip, viewedAt])
}

model WorkerTipEvent {
  id        String   @id @default(cuid())
  workerId  String
  amount    Float
  txHash    String?
  createdAt DateTime @default(now())
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, createdAt])
}

model WorkerAnalytics {
  id            String   @id @default(cuid())
  workerId      String   @unique
  totalViews    Int      @default(0)
  uniqueViews   Int      @default(0)
  totalTips     Float    @default(0)
  tipCount      Int      @default(0)
  bookmarkCount Int      @default(0)
  contactCount  Int      @default(0)
  responseRate  Float    @default(0)
  avgRating     Float    @default(0)
  reviewCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  worker        Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model SearchAnalytics {
  id           String   @id @default(cuid())
  query        String
  resultsCount Int      @default(0)
  hasFilters   Boolean  @default(false)
  /// @encrypted — PII (Medium sensitivity; retained 30 days then truncated)
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}

// ─── Issue #511: Refresh Token Rotation ──────────────────────────────────────

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

// ─── Issue #517: Idempotency Keys ────────────────────────────────────────────

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String
  userId       String?
  responseBody Json
  statusCode   Int
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([key, userId])
  @@index([expiresAt])
}

// ─── Issue #751: On-Chain Event Indexer Service ───────────────────────────────

model ContractEvent {
  id            String   @id @default(cuid())
  contractId    String
  eventName     String
  ledger        BigInt
  txIndex       Int
  eventIndex    Int
  indexed       Json     // Array of indexed parameters
  data          Json?    // Additional event data
  processedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([contractId, ledger, txIndex, eventIndex])
  @@index([contractId])
  @@index([contractId, eventName])
  @@index([contractId, eventName, ledger])
  @@index([ledger])
  @@index([createdAt])
}

model EventIndexerCursor {
  id         String   @id @default(cuid())
  contractId String   @unique
  ledger     BigInt   @default(0)
  txIndex    Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// ─── Issue #752: Wallet Integration Service ───────────────────────────────────

model StellarAccount {
  id           String    @id @default(cuid())
  publicKey    String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Float     @default(0)
  sequences    BigInt    @default(0)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

// ─── Issue #771: Secure File Upload & Media Pipeline ─────────────────────────

model MediaAsset {
  id           String   @id @default(cuid())
  originalName String
  mimeType     String
  size         Int
  thumbKey     String
  thumbUrl     String
  mediumKey    String
  mediumUrl    String
  fullKey      String
  fullUrl      String
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([uploadedById])
}

// ─── Issue #755: Escrow Orchestration ────────────────────────────────────────

model EscrowRecord {
  id            String        @id @default(cuid())
  jobId         String?
  payerId       String
  payeeId       String
  amountXlm     Float
  status        EscrowStatus  @default(pending)
  txId          String?       // Stellar transaction / contract reference
  expiresAt     DateTime
  releasedAt    DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  disputes      EscrowDispute[]

  @@index([payerId])
  @@index([payeeId])
  @@index([status])
}

model EscrowDispute {
  id          String              @id @default(cuid())
  escrowId    String
  escrow      EscrowRecord        @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  filedById   String
  reason      String
  evidence    String?
  status      EscrowDisputeStatus @default(open)
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([escrowId])
  @@index([status])
}

enum EscrowStatus {
  pending
  active
  released
  cancelled
  disputed
}

enum EscrowDisputeStatus {
  open
  under_review
  resolved
  dismissed
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  user
  curator
  admin
}

enum InteractionType {
  view
  bookmark
  tip
  contact
}

enum DisputeStatus {
  open
  under_review
  resolved
  dismissed
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum SubscriptionTier {
  free
  pro
  premium
}

enum JobStatus {
  open
  closed
  expired
  filled
}

enum JobUrgency {
  low
  normal
  urgent
}

enum ApplicationStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum ContactRequestStatus {
  pending
  accepted
  declined
}

enum InsuranceStatus {
  pending
  verified
  expired
  rejected
}

enum ReferralStatus {
  pending
  converted
  rewarded
}

model NotificationPreferences {
  id                String  @id @default(cuid())
  userId            String  @unique
  newWorkerNearby   Boolean @default(true)
  statusChange      Boolean @default(true)
  reviewReply       Boolean @default(true)
  announcements     Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Issue #notification: In-App Notifications ──────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum NotificationType {
  tip
  review
  contact
  system
  message
}

// ─── Issue #review: Helpful Votes ───────────────────────────────────────────

model ReviewHelpful {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
}

// ─── Issue #messaging: Conversations & Messages ─────────────────────────────

model Conversation {
  id           String                     @id @default(cuid())
  subject      String?
  initiatorId  String?
  initiator    User?                      @relation("ConversationInitiator", fields: [initiatorId], references: [id])
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  attachmentUrl  String?
  attachmentType String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

// ── Booking models — Issue #776 ───────────────────────────────────────────────

model Booking {
  id                  String        @id @default(cuid())
  workerId            String
  requesterId         String
  /// ISO 8601 stored as UTC
  startTime           DateTime
  /// ISO 8601 stored as UTC
  endTime             DateTime
  /// IANA timezone name the requester submitted in
  timezone            String        @default("UTC")
  serviceDescription  String
  note                String?
  status              BookingStatus @default(pending)
  cancellationReason  String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  worker    Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  requester User   @relation("BookingRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([workerId, startTime])
  @@index([requesterId, startTime])
  @@index([workerId, status])
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

// ─── Issue #749: Device & Session Management ─────────────────────────────────

model Device {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName    String    // e.g., "Chrome on MacOS", "Firefox on Windows"
  userAgent     String?
  /// @encrypted — PII (High sensitivity, AES-256-GCM; retained 90 days then anonymized)
  ipAddress     String
  lastUsedAt    DateTime  @updatedAt
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?

  @@index([userId])
  @@index([userId, revokedAt])
}
